# Aegis Ocean — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# ── AI / TTS ─────────────────────────────────────────────────────────────────
GEMINI_KEY=AIzaSyB9GVP8r7Ux5wJzPQ0SpoGpNWqdzE-t_xg
ELEVENLABS_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-west-2
S3_ALERTS_BUCKET=aegis-ocean-alerts
S3_LIVE_BUCKET=aegis-ocean-live

# ── X (Twitter) ───────────────────────────────────────────────────────────────
BEARER_TOKEN=your_x_bearer_token_here

# ── Hardware ──────────────────────────────────────────────────────────────────
# macOS:  /dev/cu.usbmodem*   (check ls /dev/cu.* after plugging in Arduino)
# Linux:  /dev/ttyACM0
# Windows: COM3
ARDUINO_PORT=/dev/cu.usbmodem14201
